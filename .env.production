# =============================================================================
# Synapse / Personal OS — PRODUCTION environment (Stage 8)
# =============================================================================
# This is a TRACKED TEMPLATE. It contains production-safe PUBLIC config and
# EMPTY placeholders for every SECRET. Real secret values are injected at deploy
# time (CI/CD secret store or a server-local override) and must NEVER be
# committed. Do not paste live keys into this file.
#
# The app validates this profile on startup and refuses to boot if it is
# insecure (debug on, wildcard CORS, SQLite, or a missing AI key).
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_NAME=Synapse
ENVIRONMENT=production
DEBUG=false

# --- Server ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---------------------------------------------------
# Points at the compose `postgres` service. POSTGRES_PASSWORD is a SECRET and
# must be supplied at deploy time (it is also referenced here).
DATABASE_URL=postgresql+psycopg://synapse:${POSTGRES_PASSWORD}@postgres:5432/synapse
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
POSTGRES_USER=synapse
POSTGRES_PASSWORD=
POSTGRES_DB=synapse

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- CORS (set to your real domain — NO wildcards in production) -------------
CORS_ORIGINS=https://app.example.com

# --- Google OAuth 2.0 (SECRETS — inject at deploy time) ----------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.example.com/api/v1/connections/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/userinfo.email

# --- Sync --------------------------------------------------------------------
SYNC_INTERVAL_MINUTES=5

# --- Telegram (SECRETS — inject at deploy time) ------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org

# --- Scheduling --------------------------------------------------------------
# Per-service override in compose: API=false, worker=true.
SCHEDULER_ENABLED=true
NOTIFICATION_POLL_MINUTES=15
DAILY_SUMMARY_HOUR=8
WORKFLOW_EVENT_POLL_MINUTES=2

# --- AI layer (KEY IS A SECRET — inject at deploy time) ----------------------
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7

# --- Knowledge base / RAG ----------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
VECTOR_BACKEND=memory
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=synapse_knowledge

# --- Observability -----------------------------------------------------------
LOG_FORMAT=json
LOG_LEVEL=INFO
METRICS_ENABLED=true
REQUEST_ID_HEADER=X-Request-ID

# --- Security hardening ------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_HEADERS_ENABLED=true
SECURE_COOKIES=true
ACCESS_TOKEN_EXPIRE_MINUTES=60
