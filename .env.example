# =============================================================================
# Synapse / Personal OS — Environment Configuration (Stage 8)
# =============================================================================
# Copy this file to one of:
#   .env              (local development; loaded by the backend directly)
#   .env.staging      (staging stack)
#   .env.production   (production stack)
# and fill in the values. NEVER commit a file containing real secrets — only
# this documented template is tracked. Secrets are injected at runtime (CI/CD
# secret store, orchestrator secrets, or a server-local untracked override).
#
# Every variable below maps 1:1 to a field on backend/config.py:Settings.
# Variables are grouped as PUBLIC CONFIG (safe to commit) vs SECRETS (never).
# =============================================================================

# ----------------------------- App (public) ---------------------------------
APP_NAME=Synapse
# development | staging | production. In production the app fails fast on an
# insecure config (debug on, wildcard CORS, SQLite, missing AI key).
ENVIRONMENT=development
DEBUG=true

# ----------------------------- Server (public) -------------------------------
HOST=0.0.0.0
PORT=8000

# --------------------------- Database (mixed) --------------------------------
# Development default is file-based SQLite (zero-ops). Production MUST use
# PostgreSQL, e.g.:
#   postgresql+psycopg://USER:PASSWORD@postgres:5432/synapse
DATABASE_URL=sqlite:///data/synapse.db
# Connection pool sizing (ignored by SQLite).
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Postgres container credentials (consumed by docker-compose.prod.yml).
# SECRET: POSTGRES_PASSWORD must be set in production.
POSTGRES_USER=synapse
POSTGRES_PASSWORD=
POSTGRES_DB=synapse

# ----------------------------- Redis (public) --------------------------------
# Shared cache + rate-limit backend. Empty = in-process fallback.
# In the compose stack: redis://redis:6379/0
REDIS_URL=

# ------------------------------ CORS (public) --------------------------------
# Comma-separated list of allowed frontend origins. A literal "*" is REJECTED
# in production. Set this to your real domain, e.g. https://app.example.com
CORS_ORIGINS=http://localhost:5173

# --------------------- Google OAuth 2.0 (SECRETS) ----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/connections/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/userinfo.email

# ---------------------------- Sync (public) ----------------------------------
SYNC_INTERVAL_MINUTES=5

# ------------------------- Telegram (SECRETS) --------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org

# ------------------------ Scheduling (public) --------------------------------
# In the compose stack the API runs with SCHEDULER_ENABLED=false and the
# dedicated worker runs with SCHEDULER_ENABLED=true (set per-service).
SCHEDULER_ENABLED=true
NOTIFICATION_POLL_MINUTES=15
DAILY_SUMMARY_HOUR=8
WORKFLOW_EVENT_POLL_MINUTES=2

# ----------------------------- AI layer --------------------------------------
# Active provider: anthropic | openai | ollama. Only the selected provider's
# key is required. KEYS ARE SECRETS.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7

# ----------------- Knowledge base / RAG (public) -----------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
VECTOR_BACKEND=memory
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=synapse_knowledge

# ------------------- Observability (public, Stage 8) -------------------------
# Log rendering: json (production) | console (dev). Level: DEBUG|INFO|WARNING.
LOG_FORMAT=console
LOG_LEVEL=INFO
METRICS_ENABLED=true
REQUEST_ID_HEADER=X-Request-ID

# ------------------ Security hardening (public, Stage 8) ---------------------
# Rate limiting is off in dev; enable it in staging/production.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
# Enable hardening headers (HSTS etc.) only behind TLS.
SECURITY_HEADERS_ENABLED=false
SECURE_COOKIES=false
ACCESS_TOKEN_EXPIRE_MINUTES=60
