# =============================================================================
# Synapse / Personal OS — STAGING environment (Stage 8)
# =============================================================================
# TRACKED TEMPLATE. Mirrors production but for the staging stack: relaxed CORS,
# verbose logging, and the staging domain. Secrets stay EMPTY and are injected
# at deploy time. Staging does not enforce the production fail-fast rules.
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_NAME=Synapse
ENVIRONMENT=staging
DEBUG=false

# --- Server ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---------------------------------------------------
DATABASE_URL=postgresql+psycopg://synapse:${POSTGRES_PASSWORD}@postgres:5432/synapse
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
POSTGRES_USER=synapse
POSTGRES_PASSWORD=
POSTGRES_DB=synapse

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- CORS (staging domain) ---------------------------------------------------
CORS_ORIGINS=https://staging.example.com

# --- Google OAuth 2.0 (SECRETS — inject at deploy time) ----------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://staging.example.com/api/v1/connections/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/userinfo.email

# --- Sync --------------------------------------------------------------------
SYNC_INTERVAL_MINUTES=5

# --- Telegram (SECRETS — inject at deploy time) ------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org

# --- Scheduling --------------------------------------------------------------
SCHEDULER_ENABLED=true
NOTIFICATION_POLL_MINUTES=15
DAILY_SUMMARY_HOUR=8
WORKFLOW_EVENT_POLL_MINUTES=2

# --- AI layer (KEY IS A SECRET — inject at deploy time) ----------------------
# Active provider: deepseek | anthropic | openai | ollama.
# To switch providers, change AI_PROVIDER and inject the matching key.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# Anthropic — swap AI_PROVIDER=anthropic and inject ANTHROPIC_API_KEY to use.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7

# --- Knowledge base / RAG ----------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
VECTOR_BACKEND=memory
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=synapse_knowledge

# --- Observability -----------------------------------------------------------
LOG_FORMAT=json
LOG_LEVEL=DEBUG
METRICS_ENABLED=true
REQUEST_ID_HEADER=X-Request-ID

# --- Security hardening ------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=200
RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_HEADERS_ENABLED=true
SECURE_COOKIES=true
ACCESS_TOKEN_EXPIRE_MINUTES=60
