# Synapse backend configuration (copy to .env)

# App
APP_NAME=Synapse
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database (SQLite file, per ARCHITECTURE.md)
DATABASE_URL=sqlite:///data/synapse.db

# CORS — frontend dev origin (Vite default)
CORS_ORIGINS=http://localhost:5173

# Google OAuth 2.0 (Stage 2 — Gmail + Calendar)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/connections/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/calendar.readonly https://www.googleapis.com/auth/userinfo.email

# Synchronization
SYNC_INTERVAL_MINUTES=5

# Telegram (Stage 3 — notification delivery + inbound commands)
# Create a bot via @BotFather to get the token; message the bot, then read your
# chat id from https://api.telegram.org/bot<token>/getUpdates. Leave empty to
# keep notifications in-app only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org

# Notification scheduling (Stage 3 — APScheduler)
SCHEDULER_ENABLED=true
NOTIFICATION_POLL_MINUTES=15
DAILY_SUMMARY_HOUR=8

# AI layer (Stage 4 — multi-provider LLM routing)
# Active provider: anthropic | openai | ollama. Only the selected provider's
# credentials are required; leave the rest empty. No keys are ever hardcoded.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Ollama runs locally and needs no API key — just a reachable base URL.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7
