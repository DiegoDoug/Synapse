# Synapse backend configuration (copy to .env)

# App
APP_NAME=Synapse
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database (SQLite file, per ARCHITECTURE.md)
DATABASE_URL=sqlite:///data/synapse.db

# CORS — frontend dev origin (Vite default)
CORS_ORIGINS=http://localhost:5173

# Google OAuth 2.0 (Stage 2 — Gmail + Calendar)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/connections/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/calendar.readonly https://www.googleapis.com/auth/userinfo.email

# Synchronization
SYNC_INTERVAL_MINUTES=5
